{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/tauri/conf-schema.json",
  "productName": "CodexBar",
  "version": "0.1.0",
  "identifier": "com.codexbar.tauri",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32@2x.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/icon.png"
    ]
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "CodexBar",
        "width": 340,
        "height": 520,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "transparent": false,
        "focus": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
